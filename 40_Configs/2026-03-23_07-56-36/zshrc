# -----------------------------
# tmux environment sync
# -----------------------------
tmuxsync() {
  [ -z "$TMUX" ] && return 0

  local val

  val=$(tmux show-environment -g TARGET_IP 2>/dev/null | sed -n 's/^TARGET_IP=//p')
  [ -n "$val" ] && export TARGET_IP="$val"

  val=$(tmux show-environment -g TARGET_NAME 2>/dev/null | sed -n 's/^TARGET_NAME=//p')
  export TARGET_NAME="$val"

  val=$(tmux show-environment -g TARGET_DIR 2>/dev/null | sed -n 's/^TARGET_DIR=//p')
  [ -n "$val" ] && export TARGET_DIR="$val"

  val=$(tmux show-environment -g OUT 2>/dev/null | sed -n 's/^OUT=//p')
  [ -n "$val" ] && export OUT="$val"

  val=$(tmux show-environment -g LOG 2>/dev/null | sed -n 's/^LOG=//p')
  [ -n "$val" ] && export LOG="$val"

  val=$(tmux show-environment -g ASSETS 2>/dev/null | sed -n 's/^ASSETS=//p')
  [ -n "$val" ] && export ASSETS="$val"

  val=$(tmux show-environment -g workdir 2>/dev/null | sed -n 's/^workdir=//p')
  [ -n "$val" ] && export workdir="$val"

  val=$(tmux show-environment -g INIT_SCAN_SOURCE 2>/dev/null | sed -n 's/^INIT_SCAN_SOURCE=//p')
  [ -n "$val" ] && export INIT_SCAN_SOURCE="$val"

  val=$(tmux show-environment -g INIT_PORTS 2>/dev/null | sed -n 's/^INIT_PORTS=//p')
  [ -n "$val" ] && export INIT_PORTS="$val"
}

tmuxsync_precmd() {
  [ -n "$TMUX" ] && tmuxsync
}

autoload -Uz add-zsh-hook
add-zsh-hook precmd tmuxsync_precmd


# -----------------------------
# target
# -----------------------------
target() {
  local ip="$1"
  local name="$2"
  local vault_base="$HOME/Vault/Target"
  local template="$HOME/Vault/Obsidian/80_Templates/Target.md"

  if [ -z "$ip" ]; then
    export TARGET_IP=""
    export TARGET_NAME=""
    export TARGET_DIR=""
    export workdir=""
    export OUT=""
    export LOG=""
    export ASSETS=""
    export INIT_SCAN_SOURCE=""
    export INIT_PORTS=""
    echo "[!] Targeting has been removed."
    return
  fi

  local target_dir="$vault_base/$ip"
  local note_file="$target_dir/${ip}.md"
  local tag="# OSCP_TARGET"

  mkdir -p "$target_dir/assets" "$target_dir/result/autorecon" "$target_dir/log"

  export TARGET_IP="$ip"
  export TARGET_NAME="$name"
  export TARGET_DIR="$target_dir"
  export workdir="$target_dir"
  export OUT="$target_dir/result"
  export LOG="$target_dir/log"
  export ASSETS="$target_dir/assets"
  export INIT_SCAN_SOURCE=""
  export INIT_PORTS=""

  if [ -n "$name" ]; then
    sudo sed -i "\| $name $tag|d; \|^$ip |d" /etc/hosts
    echo "$ip $name $tag" | sudo tee -a /etc/hosts > /dev/null
  fi

  if [ ! -f "$note_file" ]; then
    if [ -f "$template" ]; then
      cp "$template" "$note_file"
      sed -i "s|<% tp.file.title %>|$ip|g" "$note_file"
    else
      echo "[!] Template missing: $template"
      cat > "$note_file" <<EOF
# $ip ${name:+($name)}

## Target Info
- IP: $ip
- Hostname: ${name:-}

---

## Quick Start

\`\`\`zsh
target $ip ${name:-}
scaninit
\`\`\`

---

## Port Scan

Primary: \`scaninit\`

> If scaninit fails:
> - Check \`\$TARGET_IP\`
> - Check \`result/\`
> - Check \`log/\`

---

## Open Ports
-

---

## Notes
-

---

## Next Actions
-
EOF
    fi
  fi

  if [ -n "$TMUX" ]; then
    tmux set-environment -g TARGET_IP "$ip"
    tmux set-environment -g TARGET_NAME "$name"
    tmux set-environment -g TARGET_DIR "$target_dir"
    tmux set-environment -g OUT "$target_dir/result"
    tmux set-environment -g LOG "$target_dir/log"
    tmux set-environment -g ASSETS "$target_dir/assets"
    tmux set-environment -g workdir "$target_dir"
    tmux set-environment -g INIT_SCAN_SOURCE ""
    tmux set-environment -g INIT_PORTS ""
  fi

  cd "$target_dir" || return

  echo "----------------------------------------"
  echo "Target Set & Moved to $target_dir"
  echo "IP   : $TARGET_IP"
  echo "FQDN : ${TARGET_NAME:-N/A}"
  echo "----------------------------------------"
}

