# -----------------------------
# next step from port
# -----------------------------
next() {
  echo "========== NEXT ACTION =========="
  echo "[*] Ports: $INIT_PORTS"
  echo

  # -----------------------------
  # Priority 1: Web（統合）
  # -----------------------------
  if [[ "$INIT_PORTS" == *"80"* || "$INIT_PORTS" == *"443"* || "$INIT_PORTS" == *"8080"* || "$INIT_PORTS" == *"8000"* ]]; then
    echo "[P1] Web"
    echo "  → ffuf / gobuster (dir, vhost)"
    echo "  → login / upload / API"

    if [[ "$INIT_PORTS" == *"443"* ]]; then
      echo "  → SSL: cert / subdomain / TLS config"
    fi

    echo
  fi

  # -----------------------------
  # SMB
  # -----------------------------
  if [[ "$INIT_PORTS" == *"445"* || "$INIT_PORTS" == *"139"* ]]; then
    echo "[P2] SMB"
    echo "  → enum4linux-ng / smbclient"
    echo "  → anonymous / shares"
    echo
  fi

  # -----------------------------
  # AD
  # -----------------------------
  if [[ "$INIT_PORTS" == *"389"* || "$INIT_PORTS" == *"636"* || "$INIT_PORTS" == *"88"* ]]; then
    echo "[P2] AD / LDAP / Kerberos"
    echo "  → ldapsearch / kerbrute"
    echo "  → AS-REP / user enum"
    echo
  fi

  # -----------------------------
  # 認証系
  # -----------------------------
  [[ "$INIT_PORTS" == *"5985"* || "$INIT_PORTS" == *"5986"* ]] && echo "[P3] WinRM → evil-winrm"
  [[ "$INIT_PORTS" == *"3389"* ]] && echo "[P3] RDP → xfreerdp"
  [[ "$INIT_PORTS" == *"22"* ]] && echo "[P3] SSH → creds / 後回し"

  echo
  echo "-----------------------------"
  echo "[*] Always:"
  echo "  → full scan check later"
  echo "  → vhost / subdomain"
  echo "  → creds reuse"
  echo "================================"
}

# -----------------------------
# next stip from serv
# -----------------------------
nextsvc() {
  [ -n "$TMUX" ] && tmuxsync

  local file="$OUT/nmap_service.nmap"

  if [ -z "$OUT" ]; then
    echo "[!] OUT is empty"
    return 1
  fi

  if [ ! -f "$file" ]; then
    echo "[!] File not found: $file"
    echo "    Run service scan first"
    return 1
  fi

  echo "======= NEXT ACTION (SERVICE) ======="
  echo "[*] Source: $file"
  echo

  # -----------------------------
  # Web
  # -----------------------------
  if grep -Eqi 'http|https' "$file"; then
    echo "[WEB]"
    echo "  → title / tech / login / upload / API"
    echo "  → ffuf / gobuster / vhost"

    grep -qi 'apache' "$file" && echo "  → Apache: CGI / misconfig / default files"
    grep -qi 'nginx' "$file" && echo "  → Nginx: proxy / config / hidden paths"
    grep -qi 'iis' "$file" && echo "  → IIS: ASP.NET / shortname / web.config"
    grep -qi 'tomcat' "$file" && echo "  → Tomcat: manager / WAR deploy / default creds"
    grep -qi 'jetty' "$file" && echo "  → Jetty: admin / debug / Java app surface"

    if grep -qiE 'https|ssl|tls' "$file"; then
      echo "  → SSL: cert CN/SAN / subdomain / TLS config"
    fi

    echo
  fi

  # -----------------------------
  # SMB / Windows
  # -----------------------------
  if grep -qiE 'microsoft-ds|netbios|smb' "$file"; then
    echo "[SMB / WINDOWS]"
    echo "  → enum4linux-ng / smbclient"
    echo "  → anonymous / shares / users"

    grep -qi 'signing' "$file" && echo "  → check SMB signing"
    grep -qi 'samba' "$file" && echo "  → Samba version / known vulns / writable share"

    echo
  fi

  # -----------------------------
  # LDAP / Kerberos / AD
  # -----------------------------
  if grep -qiE 'ldap|kerberos' "$file"; then
    echo "[AD / LDAP / KERBEROS]"
    echo "  → ldapsearch / kerbrute / enum"
    echo "  → users / domain / AS-REP / password policy"

    grep -qi 'kerberos' "$file" && echo "  → check AS-REP roast / user enum"
    grep -qi 'ldap' "$file" && echo "  → check naming contexts / anonymous bind"

    echo
  fi

  # -----------------------------
  # WinRM / RDP / SSH
  # -----------------------------
  if grep -qi 'winrm' "$file"; then
    echo "[WINRM]"
    echo "  → evil-winrm (when creds available)"
    echo
  fi

  if grep -qi 'ms-wbt-server' "$file"; then
    echo "[RDP]"
    echo "  → xfreerdp / creds / NLA"
    echo
  fi

  if grep -qi 'ssh' "$file"; then
    echo "[SSH]"
    echo "  → creds / keys / version"
    echo "  → usually lower priority unless creds exist"
    echo
  fi

  # -----------------------------
  # FTP
  # -----------------------------
  if grep -qi 'ftp' "$file"; then
    echo "[FTP]"
    echo "  → anonymous / ls / get / put"
    echo "  → writable upload check"
    echo
  fi

  # -----------------------------
  # SMTP
  # -----------------------------
  if grep -qi 'smtp' "$file"; then
    echo "[SMTP]"
    echo "  → user enum / VRFY / EXPN"
    echo
  fi

  # -----------------------------
  # Databases
  # -----------------------------
  if grep -qi 'mysql' "$file"; then
    echo "[MYSQL]"
    echo "  → creds / anonymous / local file / version"
    echo
  fi

  if grep -qi 'postgresql' "$file"; then
    echo "[POSTGRESQL]"
    echo "  → creds / db enum / role check"
    echo
  fi

  if grep -qi 'mongodb' "$file"; then
    echo "[MONGODB]"
    echo "  → no-auth / db list / dump"
    echo
  fi

  # -----------------------------
  # Misc high-value
  # -----------------------------
  if grep -qi 'redis' "$file"; then
    echo "[REDIS]"
    echo "  → unauth / config / file write"
    echo
  fi

  if grep -qi 'elasticsearch' "$file"; then
    echo "[ELASTICSEARCH]"
    echo "  → unauth API / indices / data leak"
    echo
  fi

  if grep -qi 'docker' "$file"; then
    echo "[DOCKER]"
    echo "  → Docker API exposure / container escape surface"
    echo
  fi

  echo "-------------------------------------"
  echo "[*] Notes:"
  echo "  → update Notes / Next Actions in Obsidian"
  echo "  → compare with full scan later"
  echo "====================================="
}

# -----------------------------
# Buckup Config
# -----------------------------
buckconf() {
  local base="$HOME/Vault/Cursor/40_Configs"
  local ts=$(date +%Y-%m-%d_%H-%M-%S)
  local dest="$base/$ts"

  mkdir -p "$dest"

  echo "[*] Backing up configs → $dest"

  cp "$HOME/.zshrc" "$dest/zshrc"
  cp "$HOME/.tmux.conf" "$dest/tmux.conf"
  cp "$HOME/.config/kitty/kitty.conf" "$dest/kitty.conf"

  echo "[+] Backup completed"
}

# -----------------------------
# Restore Config
# -----------------------------
restoreconf() {
  local src="$HOME/Vault/Cursor/40_Configs"
  local ts=$(date +%Y-%m-%d_%H-%M-%S)
  local backup="$HOME/.config_backup/$ts"

  mkdir -p "$backup"

  echo "[*] Backup current configs → $backup"

  [ -f "$HOME/.zshrc" ] && cp "$HOME/.zshrc" "$backup/zshrc"
  [ -f "$HOME/.tmux.conf" ] && cp "$HOME/.tmux.conf" "$backup/tmux.conf"
  [ -f "$HOME/.config/kitty/kitty.conf" ] && cp "$HOME/.config/kitty/kitty.conf" "$backup/kitty.conf"

  echo "[*] Restoring configs from $src"

  cp "$src/zshrc" "$HOME/.zshrc"
  cp "$src/tmux.conf" "$HOME/.tmux.conf"
  cp "$src/kitty.conf" "$HOME/.config/kitty/kitty.conf"

  echo "[+] Restore completed"
  echo "[!] Backup saved: $backup"
  echo "[!] Run: source ~/.zshrc"
}